# Copy to .env and fill in. NEVER commit .env.

# --- Bybit (use TESTNET keys for v1) ---
# Create testnet keys at https://testnet.bybit.com -> API Management
BYBIT_API_KEY=your_testnet_api_key
BYBIT_API_SECRET=your_testnet_api_secret
# HARD REQUIREMENT for v1: must be true. The runner refuses to start otherwise.
BYBIT_TESTNET=true

# --- Claude (Agent SDK) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Optional overrides (otherwise config/config.yaml is used) ---
# TRADINGAI_CONFIG=config/config.yaml

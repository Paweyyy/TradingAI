# Copy to .env and fill in. NEVER commit .env.

# --- Kraken Futures (use DEMO keys for v1) ---
# Create demo keys at https://demo-futures.kraken.com -> Settings -> API Keys
KRAKEN_API_KEY=your_demo_api_key
KRAKEN_API_SECRET=your_demo_api_secret
# HARD REQUIREMENT for v1: must be true. The runner refuses to start otherwise.
KRAKEN_DEMO=true

# --- Kraken CLI MCP server (krakenfx/kraken-cli, provides order tools) ---
# Install the Kraken CLI separately; adjust if the invocation differs.
KRAKEN_MCP_COMMAND=kraken
KRAKEN_MCP_ARGS=mcp

# --- Claude (Agent SDK) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Optional overrides (otherwise config/config.yaml is used) ---
# TRADINGAI_CONFIG=config/config.yaml
